<div class="wave-top">
  <svg viewBox="0 0 1200 62" preserveAspectRatio="none">
    <path d="
      M0,-2
      Q300,60 600,30
      Q900,0 1200,30
      L1200,64
      L0,64
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<footer class="bg-info text-gray-200">
  <div class="grid grid-cols-1 md:grid-cols-2 p-2 md:px-8 md:pb-8 gap-6">
    <div class=" md:pl-10 flex flex-col justify-between items-center text-center">
      <div class="mb-6 mt-4 md:m-0">
        <%= link_to 'Home', root_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'Aikku PLANN',  aikku_plann_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'Aikku COOPCOMM', aikku_coopcomm_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'Aikku ACCESS', aikku_access_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'Our services', services_path, class: 'text-white block text-sm hover:text-secondary mb-2', title: 'test' %>
        <%= link_to 'About us', qui_sommes_nous_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
