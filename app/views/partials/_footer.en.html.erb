          <%= link_to 'Contact us', contact_path, 
            class: 'text-white block text-sm hover:text-secondary' %>
          -
          <%= link_to 'https://www.linkedin.com/company/aikku-sas',
            target: '_blank',
            class: 'inline-flex items-center justify-center gap-2 rounded-lg text-sm hover:text-secondary' do %>
            LinkedIn <%= icon("linkedin", class: "w-6 h-6 text-accent hover:text-secondary") %></i>
        <% end %>
