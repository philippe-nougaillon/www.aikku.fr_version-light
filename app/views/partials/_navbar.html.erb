<div class="navbar bg-base-100 sticky top-0 z-50 shadow justify-between">
  <div class="navbar-brand">
    <%= link_to root_path do %>
      <%= image_tag "logo.avif", width: 100, height: 100, alt: 'AIKKU',fetchpriority: "high"  %>
    <% end %>
  </div>
  <div class="lg:mr-6 flex items-center">
    <ul class="menu menu-horizontal text-lg p-0 hidden lg:flex">
      <%= render partial: 'partials/navbar_items' %>
    </ul>
    <div class="dropdown dropdown-end">
      <label tabindex="0" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-5 h-5 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </label>
      <ul tabindex="0" class="menu menu-compact dropdown-content mt-3 p-2 shadow bg-base-100 rounded-box w-52">
        <%= render partial: 'partials/navbar_items' %>
      </ul>
    </div>
  </div>
</div>