<div class="text-center reveal delay-1 m-8 md:m-30 flex flex-col lg:flex-row items-center gap-6 md:gap-16">
  <div class="flex-1 text-center lg:text-left reveal">
    <h1 class=" text-5xl md:text-7xl text-secondary mb-8 leading-tight italic tracking-tight">
      <%= title "Mutualisez mieux, dépensez moins !" %>
    </h1>
    <p class="text-xl lg:text-2xl text-gray-600 mb-10 leading-relaxed  text-justify ">
      <span class=" text-secondary">Aïkku CoopComm</span> est une     <span class="font-semibold">plateforme de mutualisation intercommunale </span> conçue pour 
      répondre aux besoins des communautés de communes, des syndicats et des collectivités territoriales. 
      Optimisez vos ressources humaines et techniques dans un outil unique et souverain.
    </p>
  </div>
  <div class="flex-1 w-full max-w-xl reveal delay-1">
    <div class="relative group">
      <div class="absolute -inset-4 bg-gradient-to-r from-blue-400 to-purple-600 rounded-full blur-3xl opacity-10 group-hover:opacity-20 transition duration-1000"></div>
      <%= image_tag "logos/CoopCommlogo.avif", 
            class: "relative bg-white shadow-xl rounded-3xl p-12 animate-pulsing", 
            alt: "CoopComm Logo" %>
    </div>
  </div>
</div>
<div class="footer-wave">
  <svg viewBox="0 0 1200 62" preserveAspectRatio="none">
    <path d="
      M0,62
      Q300,2 600,32
      Q900,62 1200,32
      L1200,62
      L0,62
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<section id="fonctionnalités" class="w-full bg-[#1f1f3d] text-white py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-4xl lg:text-6xl  mb-6">
        Tout ce dont vous avez besoin 
        <span class="text-gradient">au même endroit</span>
      </h2>
      <p class="text-[#51c7fd] font-bold text-sm uppercase tracking-[0.3em]">
        Fonctionnalités principales
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
      <% 
        features = [
          { icon: "boxes", title: "Gestion des actifs", text: "Suivi de l'inventaire du matériel et des prêts. Localisez facilement votre matériel grâce à notre carte interactive." },
          { icon: "handyman", title: "Interventions", text: "Demande émise par l'adhérent, réalisée par l'agent sur le terrain et validée en un clic." },
          { icon: "users", title: "Agents et Managers", text: "Accès segmentés : données terrain pour les agents, vision stratégique complète pour les managers." },
          { icon: "qrcode", title: "Pointage par QR Code", text: "Gagnez du temps : scannez le code pour ouvrir directement l'intervention sans saisie manuelle." },
          { icon: "euro", title: "Maîtrise budgétaire", text: "Tableau de bord en temps réel pour suivre vos indicateurs clés et vos dépenses." },
          { icon: "gears", title: "Workflow", text: "Automatisation des processus et notifications intelligentes à chaque changement d'état." },
          { icon: "message", title: "Messagerie instantanée", text: "Communication directe entre managers et agents avec modération intégrée." },
          { icon: "bell", title: "Notifications et alertes", text: "Alertes automatiques par e-mail ou WhatsApp pour informer toutes les parties prenantes." },
          { icon: "robot", title: "Prévision d'intervention (IA)", text: "Une intelligence artificielle suggère les interventions à prévoir selon l'historique." }
        ]
      %>
      <% features.each do |f| %>
        <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#51c7fd]/50 transition-all duration-300">
          <div class="flex flex-row  items-center gap-2 mb-2">
            <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-[#51c7fd]/10 group-hover:scale-110 group-hover:bg-[#51c7fd] transition-all duration-300">
              <%= icon(f[:icon], class: "text-2xl text-[#51c7fd] group-hover:text-[#1f1f3d]") %>
            </div>
            <h3 class=" text-2xl  text-white group-hover:text-[#51c7fd] transition-colors"><%= f[:title] %></h3>
          </div>
          <p class="text-gray-400 leading-relaxed text-base">
            <%= f[:text] %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none">
    <path d="M0,0 Q300,60 600,30 Q900,0 1200,30 L1200,0 L0,0 Z" fill="#1f1f3d"/>
  </svg>
</div>
<section class="flex flex-col p-10 md:p-20 md:flex-row items-center gap-16">
  <div class="flex-1 card w-full">
    <%= image_tag "coopcoomImage.png",
          class: "shadow rounded-2xl",
          alt: "Tableau de bord CoopComm sur différents écrans" %>
  </div>
  <div class="flex-1 order-1 lg:order-2">
    <h3 class="text-[#51c7fd] font-black mb-4 uppercase tracking-[0.2em] text-sm">Pourquoi Aïkku CoopComm ?</h3>
    <h2 class="text-4xl lg:text-5xl mb-8 leading-tight text-secondary">
      Une solution complète pour votre intercommunalité
    </h2>
    <p class="text-lg text-gray-600 mb-8 leading-relaxed text-justify">
      Réduisez vos coûts, améliorez l'efficacité de vos équipes et garantissez une 
      <span class="font-semibold">souveraineté numérique 100 % française</span>. Notre plateforme assure la conformité RGPD 
      tout en offrant une expérience utilisateur fluide pour tous les agents.
    </p>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% ["Réduction des coûts", "Conformité RGPD", "Efficacité terrain", "Support français"].each do |item| %>
        <li class="flex items-center gap-3 font-bold text-secondary">
          <%= icon("cercle-check", class: "w-6 h-6 text-[#51c7fd] ") %></i>
        <%= item %>
      </li>
    <% end %>
  </ul>
</div>
</div>
</section>
<section class="max-w-5xl mx-auto p-6 mb-0 md:mb-20">
  <div id="video" class="items-center flex flex-col reveal delay-2">
    <div class="text-center lg:text-left">
      <h2 class="text-3xl font-medium text-accent mb-8">Aïkku COOPCOMM en video</h2>
    </div>
    <div class=" flex justify-center"></div>
    <%= video_tag '/videos/aikkucoopcommFR.mp4',
          controls: true,
          class: 'w-full max-w-3xl rounded-2xl shadow-2xl',
          preload: 'none',
          poster: "New_logo.webp" %>
    </div>
  </div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 62" preserveAspectRatio="none">
    <path d="
      M0,62
      Q300,2 600,32
      Q900,62 1200,32
      L1200,62
      L0,62
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<section class="text-center bg-info text-white px-8 py-16 w-full ">
  <h2 class="text-3xl lg:text-5xl  mb-6">
    Envie de voir <span class="text-gradient">Aïkku COOPCOMM</span> en action ?
  </h2>
  <p class="max-w-xl mx-auto mb-8 leading-relaxed">
    Notre équipe vous propose des solutions adaptées à vos besoins,
    avec un accompagnement personnalisé et une assistance technique.
  </p>
  <%= link_to "Voir la démonstration →", "https://demo.coopcomm.fr/",
        target: "_blank",
        class: "btn btn-gradient shadow-sm shadow-white/40 mt-6 h-min transition-transform hover:scale-105" %>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none">
    <path d="M0,0 Q300,60 600,30 Q900,0 1200,30 L1200,0 L0,0 Z" fill="#1f1f3d"/>
  </svg>
</div>
<section class="grid grid-cols-1 md:grid-cols-2 gap-8 px-6 md:px-20 mb-20">
  <div class="group border border-gray-200 rounded-3xl p-8 bg-white shadow-sm hover:shadow-md transition-all duration-300 transform hover:-translate-y-1">
    <div class="flex items-start gap-4">
      <div class="bg-blue-50 p-3 rounded-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
        <%= icon("github", class: "w-6 h-6 ") %>
      </div>
      <div>
        <p class="text-xs font-bold text-accent uppercase tracking-widest mb-1">Développement</p>
        <h3 class="text-xl font-medium mb-3">Code source ouvert</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Développé en France et publié en toute transparence sur 
          <%= link_to "GitHub",
            "https://github.com/philippe-nougaillon/coopcomm",
            target: "_blank",
            class: "font-bold text-accent hover:text-secondary underline decoration-2 underline-offset-4" %>.
        </p>
      </div>
    </div>
  </div>
  <div class="group border border-gray-200 rounded-3xl p-8 bg-white shadow-sm hover:shadow-md transition-all duration-300 transform hover:-translate-y-1">
    <div class="flex items-start gap-4">
      <div class="bg-blue-50 p-3 rounded-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
        <%= icon("rocket", class: "w-6 h-6") %>
      </div>
      <div>
        <p class="text-xs font-bold text-accent uppercase tracking-widest mb-1">Support & Services</p>
        <h3 class="text-x font-medium mb-3">Besoin d'une fonctionnalité ?</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Notre équipe est à votre écoute pour des besoins spécifiques.
          <%= link_to services_path, class: "block mt-2 font-semibold text-accent hover:text-secondary transition-colors group/link" do %>
            Consultez notre offre de services personnalisés →
            <span class="block mt-2 font-semibold text-accent cursor-pointer hover:underline">
            </span>
          <% end %>
        </p>
      </div>
    </div>
  </div>
</section>
