<%
  set_meta_tags(
    title: "Bienvenue"
  )
%>
<div class="relative text-center w-full min-h-[200px] md:min-h-[300px] text-neutral-content p-10 lg:p-30  ">
  <%= image_tag "background/fondo.avif",
  class: "absolute inset-0 w-full h-full object-cover bg-cover bg-center",
  alt: "background image with two hands shaking",
  fetchpriority: "high",
  loading: "eager" %>
  <div class="absolute inset-0 bg-black/50"></div>
  <div class="relative z-10 reveal delay-1 ">
    <h1 class="pt-6 md:pt-0 text-4xl lg:text-6xl ">
      Digital <span class="text-gradient">solutions</span> serving your needs
    </h1>
    <p class="text-xl p-8 hidden md:block md:text-center lg:text-2xl text-primary-content ">
      AÏKKU translates customer needs into simple, robust, and tailored software solutions
    </p>
  </div>
</div>
<section class="w-full text-secondary-content py-20 px-10 md:p-20 text-justify reveal delay-2">
  <h2 class="text-3xl lg:text-5xl text-center mb-12">
    Our motto : <span class="text-gradient-reverse">AI for You</span>
  </h2>
  <p class="text-xl mb-3">
    Discover the <span class="font-semibold">Aïkku platform</span> and our software solutions developed for public institutions, private organizations, and higher education establishments.
  </p>
  <p class="hidden md:block">
    Digital transformation goes hand in hand with the evolution of business processes. 
    Instant access to data, from anywhere, is transforming the way we work. 
    The integration of Artificial Intelligence helps optimize these processes, improving speed, quality, and efficiency. 
    For it to be truly effective, its implementation must be designed in collaboration with operational teams.
  </p>
  <div class="flex justify-center">
    <%= link_to 'Learn more ...', services_path, 
    class: 'btn-gradient  mt-12 shadow-lg h-min transition-transform hover:scale-105 border-none' %>
  </div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 62" preserveAspectRatio="none">
    <path d="
      M0,62
      Q300,2 600,32
      Q900,62 1200,32
      L1200,62
      L0,62
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<section id="secteurs" class="w-full text-white px-10 py-20 md:p-20 bg-info">
  <h2 class="text-3xl lg:text-5xl text-center  mb-12">
    Our <span class="text-gradient">key sectors</span></h2>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mt-16">
    <div class="bg-white h-full border border-gray-100 rounded-xl overflow-hidden flex flex-col">
      <figure>
        <%= image_tag(
          "misc/students.avif",
          class: "w-full h-48 object-cover",
          alt: "Étudiants",
          loading: "lazy",
          width: 800,
          height: 450,
          
          sizes: "(max-width: 768px) 100vw, 33vw"
        ) %>
      </figure>
      <div class="card-body text-black flex flex-col flex-grow">
        <h2 class="card-title mb-4">
          Higher education </h2>
        <p class="flex-grow">Manage all your training programs and classrooms with a simple, 
          affordable, and customizable solution  </p>
        <div class="card-actions mt-6">
          <%= link_to(
            'En savoir plus sur Aikku PLANN',
            aikku_plann_path,
            class: 'btn btn-sm btn-gradient w-full shadow h-min'
          ) %>
        </div>
      </div>
    </div>
    <div class="bg-white h-full border border-gray-100 rounded-xl overflow-hidden flex flex-col">
      <figure>
        <%= image_tag(
          "misc/communauté-communes.avif",
          class: "w-full h-48 object-cover",
          alt: "Village",
          loading: "lazy",
          width: 800,
          height: 450,
          
          sizes: "(max-width: 768px) 100vw, 33vw"
        ) %>
      </figure>
      <div class="card-body text-black flex flex-col flex-grow">
        <h2 class="card-title mb-4">
          Local authorities </h2>
        <p class="flex-grow">
          Effortlessly manage cooperation and resource sharing within your inter-municipal structure (EPCI)</p>
      </p>
      <div class="card-actions mt-6">
        <%= link_to(
            'En savoir plus sur Aikku COOPCOMM',
            aikku_coopcomm_path,
            class: 'btn btn-sm btn-gradient w-full shadow h-min'
          ) %>
      </div>
    </div>
  </div>
  <div class="bg-white h-full border border-gray-100 rounded-xl overflow-hidden flex flex-col">
    <figure>
      <%= image_tag(
          "misc/dsi.avif",
          class: "w-full h-48 object-cover",
          alt: "DSI / Data Scientist qui travaille",
          loading: "lazy",
          width: 800,
          height: 450,
          
          sizes: "(max-width: 768px) 100vw, 33vw"
        ) %>
    </figure>
    <div class="card-body text-black flex flex-col flex-grow">
      <h2 class="card-title mb-4">
        IT Departments </h2>
      <p class="flex-grow">
        Manage your business data online and on the go with your no-code tool enhanced with integrated AI</p>
    </p>
    <div class="card-actions mt-6">
      <%= link_to(
            'En savoir plus sur Aikku ACCESS',
            aikku_access_path,
            class: 'btn btn-sm btn-gradient w-full shadow h-min'
          ) %>
    </div>
  </div>
</div>
</div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none">
    <path d="
      M0,0
      Q300,60 600,30
      Q900,0 1200,30
      L1200,0
      L0,0
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<section id="expérience" class="px-10 py-20 md:p-20">
  <h2 class="text-3xl text-center lg:text-5xl  mb-12">Over 20 years of experience</h2>
  <p class="lg:text-2xl text-center">
    Aïkku is a young company, but its founders have been working together for over 20 years.
    <br>
    Together, they have delivered numerous validated projects in the healthcare sector,
    <br>
    for clients such as <span class="font-semibold">Sanofi</span> (eCRF), <span class="font-semibold">L’Oréal</span> (ePRO), <span class="font-semibold">PPRS Research</span> (CDMS), <span class="font-semibold">AirJin</span> (IoT)
  </p>
</section>
<section id="clients" class="flex flex-col justify-center p-15 ">
  <h2 class="text-center text-3xl lg:text-5xl  mb-12 ">
    They trust <span class="text-gradient">us</span>
  </h2>
  <div class="flex flex-wrap justify-center items-center gap-8 ">
    <div class="w-64 h-64 rounded flex items-center">
      <%= link_to "https://www.madmoselle.com", target: "_blank" do %>
        <%= image_tag "logos/madmoselle.avif", class:"mx-auto p-8", alt: 'Mad & Moselle logo' %>
      <% end %>
    </div>
    <div class="w-64 h-64 rounded flex items-center">
      <%= link_to "https://www.grohe.com", target: "_blank" do %>
        <%= image_tag "logos/grohe.avif", class:"mx-auto p-8", alt: 'GROHE logo' %>
      <% end %>
    </div>
    <div class="w-64 h-64 rounded flex items-center">
      <%= link_to "https://www.iae-paris.com", target: "_blank" do %>
        <%= image_tag "logos/iaelogo.avif", class:"mx-auto p-8", alt: 'IAE Paris-Sorbonne logo' %>
      <% end %>
    </div>
    <div class="w-64 h-64 rounded flex items-center">
      <%= link_to "https://www.fnaut.fr/", target: "_blank" do %>
        <%= image_tag "logos/fnaut.avif", class:"mx-auto p-8", alt: 'Logo FNAUT' %>
      <% end %>
    </div>
    <div class="w-64 h-64 rounded flex items-center">
      <%= link_to "https://www.infogene.fr", target: "_blank" do %>
        <%= image_tag "logos/infogene.avif", class:"mx-auto p-8 rounded", alt: 'Infogene logo' %>
      <% end %>
    </div>
  </div>
</section>