<section id="mention_légales_content" class="px-6 md:px-20 py-16">
  <div class="max-w-5xl mx-auto space-y-12">
    <header class="space-y-4">
      <h1 class=" text-5xl lg:text-6xl text-accent italic">
        <%= title "Mentions légales" %>
      </h1>
      <p class="text-lg md:text-xl text-slate-600 leading-relaxed">
        Informations importantes sur l'éditeur, le développement et l'hébergement du site Aïkku.
      </p>
    </header>
    <div class="grid gap-8">
      <article class="rounded-[2rem] border border-base-200 bg-base-100 p-8 shadow-sm">
        <h2 class="text-2xl lg:text-3xl  text-accent mb-4">
          1. Éditeur du site
        </h2>
        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p class="font-semibold text-lg text-slate-900"><%= @sitename %></p>
          <address class="not-italic space-y-2">
            <p>Directeur de la publication : Philippe Nougaillon</p>
            <p>
              Aïkku SAS<br>
              Tour Ariane - La Défense<br>
              5 Place de la Pyramide<br>
              92800 Puteaux<br>
              France
            </p>
            <p>SIREN : 934 780 735 R.C.S. Nanterre</p>
            <p>Contact : <%= mail_to "contact@aikku.eu", class: "link" %></p>
          </address>
        </div>
      </article>
      <article class="rounded-[2rem] border border-base-200 bg-base-100 p-8 shadow-sm">
        <h2 class="text-2xl lg:text-3xl  text-accent mb-4">
          2. Conception et développement
        </h2>
        <p class="text-gray-700 leading-relaxed">
          Création du site en 2024. Ce site a été conçu et développé par nos soins avec Ruby on Rails.
        </p>
      </article>
      <article class="rounded-[2rem] border border-base-200 bg-base-100 p-8 shadow-sm">
        <h2 class="text-2xl lg:text-3xl  text-accent mb-4">
          3. Hébergement
        </h2>
        <div class="space-y-3 text-gray-700 leading-relaxed">
          <p>
            <span class="font-semibold">OVH Cloud</span><br>
            2 rue Kellermann,<br>
            59100 Roubaix <br>
            France
          </p>
          <p>
            Contact: <%= link_to "ovh.com", "https://www.ovh.com/fr/", target: '_blank', class: 'link' %>
          </p>
        </div>
      </article>
    </div>
    <footer class="text-sm text-slate-500">
      <p class="font-bold">2026 © <%= @sitename %> – Tous droits réservés.</p>
    </footer>
  </div>
</section>