<section class="text-center reveal delay-1 m-0 md:m-8">
  <h1 class=" text-5xl md:text-6xl text-secondary mb-12 pt-8 italic">
    <%= title "Manage your courses and classrooms. Without complexity" %>
  </h1>
  <h3 class="text-lg lg:text-2xl p-0 md:p-12">
    Developed in collaboration with IAE Paris-Sorbonne,
    <span class="text-secondary">Aïkku PLANN</span>
    is a <span class="font-semibold">scheduling and classroom management software</span>
    It is tailored to the needs of universities, business schools, and specialized training institutes.
  </h3>
</section>
<section>
  <div class="flex flex-col md:flex-row border-t border-b border-gray-300 reveal delay-2 p-0 md:p-10">
    <div class="flex-1 text-center py-7 px-4 border-b md:border-b-0 md:border-r border-gray-300">
      <p class="text-4xl font-medium text-accent">500+</p>
      <p class="text-sm text-gray-400 mt-1">Programs managed</p>
    </div>
    <div class="flex-1 text-center py-7 px-4 border-b md:border-b-0 md:border-r border-gray-300">
      <p class="text-4xl font-medium text-accent">900</p>
      <p class="text-sm text-gray-400 mt-1">Instructors</p>
    </div>
    <div class="flex-1 text-center py-7 px-4 border-b md:border-b-0 md:border-r border-gray-300">
      <p class="text-4xl font-medium text-accent">60 000</p>
      <p class="text-sm text-gray-400 mt-1">Scheduled classes</p>
    </div>
    <div class="flex-1 text-center py-7 px-4">
      <p class="text-4xl font-medium text-accent">Since 2017</p>
      <p class="text-sm text-gray-400 mt-1">25 administrators</p>
    </div>
  </div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 62" preserveAspectRatio="none">
    <path d="
      M0,62
      Q300,2 600,32
      Q900,62 1200,32
      L1200,62
      L0,62
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<section id="fonctionnalités" class="w-full bg-[#1f1f3d] text-white py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-4xl lg:text-6xl mb-6">
        Everything you need
        <span class="text-gradient">in one place</span>
      </h2>
      <p class="text-[#51c7fd] font-bold text-sm uppercase tracking-[0.3em]">
        Core features
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
      <% 
        features = [
          { icon: "calendar-days", title: "Course scheduling", text: "Create or modify schedules for a set of courses and/or a session
        in just a few clicks. The software automatically selects an 
        available classroom. 
      " },
          { icon: "salles", title: "Room occupancy", text: "View available time slots by day, week, and classroom. 
        Manage room capacity across your institution. 
        Get alerts when a room reaches its capacity." },

      { icon: "teachers", title: "Instructors and students", text: "Centralize all information for each instructor. 
        Track actual teaching time for adjunct lecturers
        to simplify billing. Notify students by email
        or SMS in case of schedule changes 
     " },
          { icon: "formation", title: "Programs", text: "Identify each program in the schedule using color codes.
        Access the list of instructors. Easily manage
        course hours: completed, scheduled, and remaining. 
     " },
          { icon: "import", title: "Import and export", text: "Import large volumes of data in Excel 
          (XLS) and CSV formats: courses, programs, students… All 
          data can be exported in XLS format. 
     " },
          { icon: "sign", title: "Attendance tracking", text: "Thanks to Edusign integration, sign digitally 
          directly from the student’s smartphone or computer 
          at the beginning of each session.  
     " }]

    %>
      <% features.each do |f| %>
        <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#51c7fd]/50 transition-all duration-300">
          <div class="flex flex-row  items-center gap-2 mb-2">
            <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-[#51c7fd]/10 group-hover:scale-110 group-hover:bg-[#51c7fd] transition-all duration-300">
              <%= icon(f[:icon], class: "text-2xl text-[#51c7fd] group-hover:text-[#1f1f3d]") %>
            </div>
            <h3 class=" text-2xl text-white group-hover:text-[#51c7fd] transition-colors"><%= f[:title] %></h3>
          </div>
          <p class="text-gray-400 leading-relaxed text-base">
            <%= f[:text] %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none">
    <path d="M0,0 Q300,60 600,30 Q900,0 1200,30 L1200,0 L0,0 Z" fill="#1f1f3d"/>
  </svg>
</div>
<section id="responsive" class="flex flex-col p-10 md:p-20 md:flex-row items-center gap-16">
  <div class="flex-1 card w-full">
    <%= image_tag "misc/planning-responsive.png",
          class: "shadow rounded-2xl",
          alt: "Software across multiple screens" %>
  </div>
  <div class="flex-1 order-1 lg:order-2">
    <h3 class="text-[#51c7fd] font-black mb-4 uppercase tracking-[0.2em] text-sm">
      Information always available
    </h3>
    <h2 class="text-4xl lg:text-5xl  mb-8 leading-tight text-secondary">
      Your schedule accessible on any device
    </h2>
    <p class="text-lg text-gray-600 mb-8 leading-relaxed text-justify">
      The application adapts perfectly to all screen sizes. Display the daily schedule on your institution’s digital screens, updated in real time.
      <br>
      <br>
      Students and instructors can access the schedule from their phone, computer, or tablet, 24/7. With one click, subscribe your calendar (Google, Outlook, or Apple) to your schedule so your classes and sessions update automatically.
    </p>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% [
        "Cross-device accessibility",
        "Real-time schedule updates",
        "24/7 availability",
        "Seamless calendar synchronization"
      ].each do |item| %>
        <li class="flex items-center gap-3 font-bold text-secondary">
          <%= icon("cercle-check", class: "w-6 h-6 text-[#51c7fd] ") %>
          <%= item %>
        </li>
      <% end %>
    </ul>
  </div>
</section>
<section class="px-6 md:px-20 pb-20 pt-10">
  <h2 class="text-accent text-left mb-6 font-medium text-2xl uppercase tracking-wider">
    They trust us
  </h2>
  <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
    <div id="confiance" class="flex-1">
      <div class="bg-white shadow-xl rounded-2xl p-8 flex flex-col border border-gray-100">
        <%= icon("quote", class: "w-6 h-6 mb-4 text-left text-accent ") %></i>
      <p class="text-gray-700 text-justify leading-relaxed text-sm md:text-base">
        Philippe Nougaillon delivers sustainable, reliable solutions 
        and prioritizes simplicity in his development approach.
        A proponent of frugal innovation, he provides 
        original, robust, and perfectly adapted solutions 
        to his clients. He listens carefully and demonstrates 
        strong pedagogical skills in agile processes.
      </p>
      <div class="mt-8 border-t pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div>
          <%= link_to "https://www.linkedin.com/in/philippe-eynaud-3a3ab835/",
               class: "flex items-center gap-1.5 font-medium text-accent " do %>
            <%= icon("linkedin", class: "w-6 h-6 ") %></i> Philippe EYNAUD
        <% end %>
        <p class="text-xs text-gray-500 mt-1">
          Professor of management sciences at IAE Paris.
          <br>
          Author of
          <%= link_to "'Information Systems Management in Its Complexity'", 
                          "https://www.amazon.fr/management-syst%C3%A8me-dinformation-dans-complexit%C3%A9/dp/1784055026/ref=sr_1_5?qid=1687595735", 
                          class: "link italic no-underline", target: '_blank' %>. (2018) ISTE Editions.  
        </p>
      </div>
      <%= image_tag "logos/iaelogo.avif", class: "h-10 w-auto opacity-80", alt: "IAE PARIS logo" %>
    </div>
  </div>
</div>
<div id="confiance2" class="flex-1">
  <div class="bg-white shadow-xl rounded-2xl p-8 flex flex-col border border-gray-100">
    <%= icon("quote", class: "w-6 h-6 mb-4 text-left text-accent ") %></i>
  <p class="text-gray-700 text-justify leading-relaxed text-sm md:text-base">
    I had the pleasure of working with the Aïkku team on the deployment of the Planning-IAE tool.
    What a great experience! The Aïkku team truly embodies the "user-centric approach" I teach my students. 
    They listen carefully and effectively translate user needs into concrete solutions through co-creation. 
    A smooth and efficient collaboration that I highly recommend.
  </p>
  <div class="mt-8 border-t pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
    <div>
      <%= link_to "https://www.linkedin.com/in/marieevelaporte/",class: "flex items-center gap-1.5 font-medium text-accent " do %>
        <%= icon("linkedin", class: "w-6 h-6 ") %> Marie-Eve LAPORTE
      <% end %>
      <p class="text-xs text-gray-500 mt-1">
        Professor, 'Innovation Management & Future of Healthcare'
      </p>
    </div>
    <%= image_tag "logos/iaelogo.avif", class: "h-10 w-auto opacity-80", alt: "IAE PARIS logo" %>
  </div>
</div>
</div>
</div>
</section>
<section class="max-w-5xl mx-auto p-6 mb-0 md:mb-20">
  <div id="video" class="items-center flex flex-col reveal delay-2">
    <div class="text-center lg:text-left">
      <h2 class="text-3xl font-medium text-accent mb-8">Aïkku PLANN video</h2>
    </div>
    <div class=" flex justify-center"></div>
    <%= video_tag '/assets/videos/Aikkuplann.mp4',
          controls: true,
          class: 'w-full max-w-3xl rounded-2xl shadow-2xl',
          preload: 'none',
          poster: "New_logo.webp" %>
    </div>
  </div>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 62" preserveAspectRatio="none">
    <path d="
      M0,62
      Q300,2 600,32
      Q900,62 1200,32
      L1200,62
      L0,62
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>
<section class="text-center bg-info text-white px-8 py-16  w-full ">
  <h2 class="text-3xl lg:text-5xl mb-6">
    Want to see <span class="text-gradient">Aïkku PLANN</span> in action?
  </h2>
  <p class="max-w-xl mx-auto mb-8 leading-relaxed">
    Our team offers solutions tailored to your needs,
    with personalized support and technical assistance.
  </p>
  <%= link_to "View the demo →", "https://plann.aikku.eu",
        target: "_blank",
        class: "btn btn-gradient shadow-sm shadow-white/40 mt-6 h-min transition-transform hover:scale-105" %>
</section>
<div class="footer-wave">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none">
    <path d="M0,0 Q300,60 600,30 Q900,0 1200,30 L1200,0 L0,0 Z" fill="#1f1f3d"/>
  </svg>
</div>
<section class="grid grid-cols-1 md:grid-cols-2 gap-8 px-6 pt-20 md:px-20 mb-20">
  <div class="group border border-gray-200 rounded-3xl p-8 bg-white shadow-sm hover:shadow-md transition-all duration-300 transform hover:-translate-y-1">
    <div class="flex items-start gap-4">
      <div class="bg-blue-50 p-3 rounded-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
        <%= icon("github", class: "w-6 h-6 ") %>
      </div>
      <div>
        <p class="text-xs font-bold text-accent uppercase tracking-widest mb-1">Development</p>
        <h3 class="text-xl   mb-3">Open source code</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Developed in France and published transparently on 
          <%= link_to "GitHub",
            "https://github.com/philippe-nougaillon/Planning_IAE",
            target: "_blank",
            class: "font-bold text-accent hover:text-secondary underline decoration-2 underline-offset-4" %>.
        </p>
      </div>
    </div>
  </div>
  <div class="group border border-gray-200 rounded-3xl p-8 bg-white shadow-sm hover:shadow-md transition-all duration-300 transform hover:-translate-y-1">
    <div class="flex items-start gap-4">
      <div class="bg-blue-50 p-3 rounded-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
        <%= icon("rocket", class: "w-6 h-6") %>
      </div>
      <div>
        <p class="text-xs font-bold text-accent uppercase tracking-widest mb-1">Support & Services</p>
        <h3 class="text-xl  mb-3">Need a specific feature?</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Our team is available to support your specific needs.
          <%= link_to services_path, class: "block mt-2 font-semibold text-accent hover:text-secondary transition-colors group/link" do %>
            Explore our custom service offerings →
            <span class="block mt-2 font-semibold text-accent cursor-pointer hover:underline">
            </span>
          <% end %>
        </p>
      </div>
    </div>
  </div>
</section>